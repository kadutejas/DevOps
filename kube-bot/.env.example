# ================================================================
# kube-bot local development variables
# Copy this file to .env and fill in real values.
# NEVER commit the filled .env – it is in .gitignore.
# ================================================================

# ── Required ──────────────────────────────────────────────────
# Your Slack Bot Token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-replace-me

# ── Optional ──────────────────────────────────────────────────
# Slack channel to post alerts in
SLACK_CHANNEL=#kubernetes-alerts

# Kubernetes namespace to watch ("" = all namespaces)
WATCH_NAMESPACE=

# Comma-separated namespaces to ignore
IGNORED_NAMESPACES=kube-system,kube-public,kube-node-lease

# Seconds before the same pod is re-alerted (default = 30 min)
ALERT_COOLDOWN_SECONDS=1800

# Path to your rules.yaml for local development
RULES_CONFIG_PATH=./config/rules.yaml

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
